# ============================================================
# rdo-agent — Configuração de ambiente
# ============================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env no Git (já está no .gitignore).

# ---- APIs externas ----
# Obter em https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Obter em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ---- Modelos ----
# Modelo Claude para o agente-engenheiro (Sprint 4)
CLAUDE_MODEL=claude-sonnet-4-6
# Opções: claude-opus-4-7 (melhor qualidade, mais caro)
#         claude-sonnet-4-6 (custo-benefício, default)
#         claude-haiku-4-5 (classificação rápida, barato)

# ---- Paths ----
# Raiz das vaults de obras (uma pasta por CODESC)
RDO_VAULTS_ROOT=/mnt/d/VALE_NOBRE/rdo_vaults

# ---- Comportamento ----
# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Modo seco: não faz chamadas de API (útil para testar Sprint 1 isolada)
DRY_RUN=false
